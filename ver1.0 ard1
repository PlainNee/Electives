#include <Wire.h> 
#include <LiquidCrystal_I2C.h>
#include <OneWire.h>
#include <DallasTemperature.h>

// --- HARDWARE CONFIG ---
LiquidCrystal_I2C lcd(0x27, 16, 2);

#define ONE_WIRE_BUS 4 
OneWire oneWire(ONE_WIRE_BUS);
DallasTemperature sensors(&oneWire);

const int selectPin = 2;
const int navPin    = 3;
const int relayPin  = 9; // Added Relay Control

// --- GLOBAL VARIABLES ---
int currentMenu = 0;      // 0:Main, 1:Sub, 2:Group, 3:ManTemp, 4:ManTime, 5:Texture, 6:Running
int currentPosition = 1;  
int maxOptions = 2;       
int foodCategory = 0;     

String selectedPreset = "None"; 
long totalSeconds = 0;          
int selectedTemp = 0;           
int manualTemp = 30;            
int manualTime = 1;             
float currentSensorTemp = 0.0;  
bool isManualActive = false;    
bool presetLoaded = false;      

unsigned long startTime = 0;
bool lastNavState    = HIGH;
bool lastSelectState = HIGH;

void setup() {
  lcd.init();
  lcd.backlight();
  sensors.begin(); 
  
  pinMode(selectPin, INPUT_PULLUP);
  pinMode(navPin, INPUT_PULLUP);
  pinMode(relayPin, OUTPUT);
  digitalWrite(relayPin, LOW); // Ensure heater is off at start
  
  updateDisplay();
}

void loop() {
  // --- OPERATION LOGIC ---
  if (currentMenu == 6) {
    readTemperature(); 
    maintainHeat();    // Control the relay
    updateCountdown();
    return; 
  }

  // --- MENU NAVIGATION ---
  bool navRead    = digitalRead(navPin);
  bool selectRead = digitalRead(selectPin);

  if (navRead == LOW && lastNavState == HIGH) {
    if (currentMenu == 3) {
      manualTemp += 5; if (manualTemp > 70) manualTemp = 30;
    } 
    else if (currentMenu == 4) {
      manualTime++; if (manualTime > 16) manualTime = 1;
    }
    else {
      currentPosition++;
      if (currentPosition > maxOptions) currentPosition = 1;
    }
    updateDisplay();
    delay(150); 
  }
  lastNavState = navRead;

  if (selectRead == LOW && lastSelectState == HIGH) {
    handleSelection();
    delay(150);
  }
  lastSelectState = selectRead;
}

void readTemperature() {
  static unsigned long lastRequest = 0;
  if (millis() - lastRequest >= 750) {
    sensors.requestTemperatures(); 
    float tempC = sensors.getTempCByIndex(0);
    if (tempC != -127.0) {
      currentSensorTemp = tempC;
    }
    lastRequest = millis();
  }
}

void maintainHeat() {
  // Simple Hysteresis: Turn on if 1 degree below target, off at target
  if (currentSensorTemp < (selectedTemp - 1)) {
    digitalWrite(relayPin, HIGH); 
  } else if (currentSensorTemp >= selectedTemp) {
    digitalWrite(relayPin, LOW);
  }
}

void handleSelection() {
  if (currentMenu == 0) { 
    if (currentPosition == 1) { 
      if (!presetLoaded) {
        lcd.clear(); lcd.print("Select a preset!");
        delay(2000); updateDisplay();
      } else {
        startTimer();
      }
    } else {
      currentMenu = 1; currentPosition = 1; maxOptions = 4;
      updateDisplay();
    }
  } 
  else if (currentMenu == 1) { 
    if (currentPosition == 1) { currentMenu = 2; currentPosition = 1; maxOptions = 2; }
    else if (currentPosition == 2) { currentMenu = 3; }
    else if (currentPosition == 3) { displayCurrent(); }
    else if (currentPosition == 4) { currentMenu = 0; currentPosition = 1; maxOptions = 2; }
    updateDisplay();
  }
  else if (currentMenu == 2) { 
    foodCategory = currentPosition; 
    currentMenu = 5; currentPosition = 1; maxOptions = 2;
    updateDisplay();
  }
  else if (currentMenu == 5) { 
    presetLoaded = true;
    isManualActive = false;
    if (foodCategory == 1) { // Fruits
      if (currentPosition == 1) { selectedPreset = "Soft Chewy Fr."; selectedTemp = 55; totalSeconds = 5 * 3600L; }
      else { selectedPreset = "Crispy Fruit"; selectedTemp = 60; totalSeconds = 9 * 3600L; }
    } else { // Veg
      if (currentPosition == 1) { selectedPreset = "Tender Veg."; selectedTemp = 45; totalSeconds = 3 * 3600L; }
      else { selectedPreset = "Crispy Veg."; selectedTemp = 60; totalSeconds = 8 * 3600L; }
    }
    currentMenu = 1; currentPosition = 1; maxOptions = 4;
    updateDisplay();
  }
  else if (currentMenu == 3) { currentMenu = 4; updateDisplay(); }
  else if (currentMenu == 4) { 
    presetLoaded = true;
    isManualActive = true; 
    selectedTemp = manualTemp;
    totalSeconds = (long)manualTime * 3600L;
    currentMenu = 1; currentPosition = 2; maxOptions = 4;
    updateDisplay();
  }
}

void startTimer() {
  currentMenu = 6;
  startTime = millis();
  lcd.clear();
}

void updateCountdown() {
  unsigned long now = millis();
  long elapsed = (now - startTime) / 1000;
  long currentRemaining = totalSeconds - elapsed;

  if (currentRemaining < 0) {
    digitalWrite(relayPin, LOW); // Safety: Turn off heater
    lcd.clear();
    lcd.print("      Done!     ");
    delay(3000);
    currentMenu = 0;
    presetLoaded = false;
    updateDisplay();
    return;
  }

  static long lastRefresh = 0;
  if (millis() - lastRefresh >= 1000) { 
    lastRefresh = millis();
    
    // Top Line: Temp only
    lcd.setCursor(0, 0);
    lcd.print("Temp: "); 
    lcd.print((int)currentSensorTemp); 
    lcd.print((char)223);
    lcd.print("C          "); 

    // Bottom Line: Time
    int h = currentRemaining / 3600;
    int m = (currentRemaining % 3600) / 60;
    int s = currentRemaining % 60;
    lcd.setCursor(0, 1);
    lcd.print("Time: ");
    if(h<10) lcd.print("0"); lcd.print(h); lcd.print(":");
    if(m<10) lcd.print("0"); lcd.print(m); lcd.print(":");
    if(s<10) lcd.print("0"); lcd.print(s);
  }
}

void displayCurrent() {
  lcd.clear();
  lcd.setCursor(0,0);
  lcd.print("Active Preset:");
  lcd.setCursor(0,1);
  if (isManualActive) {
    lcd.print(String(manualTemp) + " deg. - " + String(manualTime) + " hrs.");
  } else {
    lcd.print(selectedPreset);
  }
  delay(2500);
}

void updateDisplay() {
  lcd.clear();
  if (currentMenu == 0) {
    lcd.setCursor(0, 0); lcd.print("Smart Dehydrator");
    lcd.setCursor(0, 1);
    if (currentPosition == 1) lcd.print(">Start   Preset");
    else lcd.print(" Start  >Preset");
  } 
  else if (currentMenu == 1) {
    lcd.setCursor(0, 0);
    lcd.print(currentPosition == 1 ? ">Presets " : " Presets ");
    lcd.setCursor(9, 0);
    lcd.print(currentPosition == 2 ? ">Manual" : " Manual");
    lcd.setCursor(0, 1);
    lcd.print(currentPosition == 3 ? ">Current " : " Current ");
    lcd.setCursor(9, 1);
    lcd.print(currentPosition == 4 ? ">Return" : " Return");
  }
  else if (currentMenu == 2) {
    lcd.setCursor(0, 0);
    lcd.print(currentPosition == 1 ? "    >Fruits     " : "     Fruits     ");
    lcd.setCursor(0, 1);
    lcd.print(currentPosition == 2 ? "  >Vegetables   " : "   Vegetables   ");
  }
  else if (currentMenu == 5) {
    lcd.setCursor(0, 0);
    if (foodCategory == 1) {
      lcd.print(currentPosition == 1 ? "  >Soft Chewy   " : "   Soft Chewy   ");
      lcd.setCursor(0, 1);
      lcd.print(currentPosition == 2 ? "    >Crispy     " : "     Crispy     ");
    } else { // Veg Textures
      lcd.print(currentPosition == 1 ? "    >Tender     " : "     Tender     ");
      lcd.setCursor(0, 1);
      lcd.print(currentPosition == 2 ? "    >Crispy     " : "     Crispy     ");
    }
  }
  else if (currentMenu == 3) {
    lcd.setCursor(0, 0); lcd.print("   Set Temp.    ");
    lcd.setCursor(0, 1); lcd.print("   "); lcd.print(manualTemp); lcd.print(" degrees     ");
  }
  else if (currentMenu == 4) {
    lcd.setCursor(0, 0); lcd.print("    Set Time    ");
    lcd.setCursor(0, 1); lcd.print("     "); lcd.print(manualTime); lcd.print(" hrs        ");
  }
}
